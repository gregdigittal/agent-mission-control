# ─── Supabase (required) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── REST API — server-side (Vercel serverless functions) ────────────────────

# Bearer token for REST API authentication.
# Generate a strong random value, e.g.: openssl rand -hex 32
AGENT_MC_API_SECRET=your-secret-here

# Path to the bridge IPC command directory (used by Vercel functions to queue commands).
# The bridge daemon polls this directory for new commands.
BRIDGE_COMMAND_DIR=~/.agent-mc/commands

# Supabase service-role key — used server-side ONLY (never expose to the browser).
# Found in: Supabase Dashboard → Project Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=

# ─── REST API — client-side (dashboard) ──────────────────────────────────────

# Optional base URL for REST API calls from the browser (blank = same origin).
# Set this when the API is deployed to a different domain than the dashboard.
VITE_API_BASE_URL=

# Optional API token for dashboard → API calls (if your deployment requires it).
VITE_API_TOKEN=

# ─── SSO / OIDC (optional) ───────────────────────────────────────────────────

# Provider slug for OIDC SSO login.  Must match the slug configured in the
# Supabase Dashboard under Authentication → Providers.
# Leave blank (or omit) to hide the "Sign in with SSO" button entirely.
VITE_SSO_PROVIDER_SLUG=
