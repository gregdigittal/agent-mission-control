# Agent Bridge — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# Required only when using the decompose_objective command.
# The bridge runs fully without this key; it is only used by the task
# decomposition engine (bridge/src/decompose/).
ANTHROPIC_API_KEY=

# Optional: Supabase credentials (set supabase.enabled=true in config.json to activate)
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_ANON_KEY=
